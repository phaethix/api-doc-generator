# Environment Configuration Template
# Copy this file to .env and modify the values for your environment

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_TITLE=API 文档生成器

# Development Options
DENO_ENV=development
LOG_LEVEL=info

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# AI / LLM Configuration
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# To use a different provider (Anthropic via proxy, Google, DeepSeek, Qwen,
# or local Ollama), change OPENAI_BASE_URL to that provider's OpenAI-compatible
# endpoint and update LLM_MODEL accordingly.
